# Version + Port (for Docker Compose)
MW_VERSION=1.44
MW_PORT=8080

# Database
MEDIAWIKI_DB_NAME=hitchwiki
MEDIAWIKI_DB_USER=hitchwiki
MEDIAWIKI_DB_PASSWORD=xxx
MEDIAWIKI_DB_HOST=172.19.0.1
MEDIAWIKI_DB_PORT=3306

# Cookie - does not need to be set
MEDIAWIKI_COOKIE_DOMAIN=
MEDIAWIKI_COOKIE_PREFIX=

# Site info
MEDIAWIKI_SITE_DOMAIN=localhost:8080
MEDIAWIKI_SITENAME=Hitchwiki
MEDIAWIKI_SERVER="http://localhost:8080"
MEDIAWIKI_DEFAULT_LANG=en

# Email
MEDIAWIKI_EMAIL_CONTACT=contact@hitchwiki.org
MEDIAWIKI_EMAIL_SENDER=noreply@hitchwiki.org

# SMTP (e.g. SparkPost)
MEDIAWIKI_SMTP_HOST=localhost
MEDIAWIKI_SMTP_PORT=1025
MEDIAWIKI_SMTP_USER=
MEDIAWIKI_SMTP_PASS=
MEDIAWIKI_SMTP_DOMAIN=

# Anti-spam keys - does not need to be set
MEDIAWIKI_AKISMET_KEY=

# Captcha keys
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Secret keys
MEDIAWIKI_SECRET_KEY=""
MEDIAWIKI_UPGRADE_KEY=""

# OAuth
# Generate with: php -r 'echo base64_encode(random_bytes(32)) . "\n";'
OAUTH_SECRET_KEY=""

# Newsletter one-click unsubscribe (Special:Unsubscribe). Must match the value
# given to the newsletter sender. Generate with:
#   php -r 'echo bin2hex(random_bytes(32)) . "\n";'
UNSUBSCRIBE_SECRET=""


# Optional
DEBUG=1
DEVELOPMENT=1
